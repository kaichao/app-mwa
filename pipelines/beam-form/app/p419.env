# ##########################
# 一、计算环境
# ##########################
CLUSTER=p419
NODES=c.+
# 24节点
#NODES=n-00([01][0-9]|2[0-3])
TARGET_USER=cstu0030
TARGET_PORT=50022
GROUP_NODES=
PRESTO_NODES=n-.+
NUM_GROUPS=1
GROUP_SLOTS=

# ##########################
# 二、数据存储
# ##########################
LOCAL_TMPDIR=/tmp/scalebox-0/mydata/mwa
LOCAL_SHMDIR=/dev/shm/scalebox-0/mydata/mwa

SOURCE_JUMP=
TARGET_JUMP=

ORIGIN_ROOT=astro@10.100.1.30:10022/data1/mydata/mwa
PRELOAD_ROOT=
# 用vpath管理preload路径
PRELOAD_VPATH=
STAGING_ROOT=
FINAL_ROOT=

# 数据
POINTING_RANGE=
TIME_STEP=

# ##########################
# 三、容器运行时及镜像代码
# ##########################
ROCM_COMMAND='singularity exec --rocm --env ROCR_VISIBLE_DEVICES=((@seq)) {{ENVS}} {{VOLUMES}} {{IMAGE}} goagent'
COMMAND_TEMPLATE=

# code相关
CODE_BASE=/public/home/cstu0030/app-mwa/pipelines/beam-form/modules

FILE_COPY=/public/home/cstu0030/singularity/scalebox/file-copy.sif
MWA_VCSTOOLS=/public/home/cstu0030/singularity/app-mwa/mwa-vcstools.sif
DOWN_SAMPLE=/public/home/cstu0030/singularity/app-mwa/down-sampler.sif

# ##########################
# 四、流控与准入控制
# ##########################
# 准入控制
BEAM_MAKE_FREE_GB='((@seq*5+11))'

# 流控相关
FIRST_BW_LIMIT=400m
BW_LIMIT=30m

NUM_BEAM_MAKE=4
